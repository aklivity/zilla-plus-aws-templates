{
  "SecurePrivateAccess":
  {
    "vpcId": "<your Amazon MSK Serverless VPC ID>",
    "subnetIds": [
      "<your Amazon MSK Serverless subnetId-1>",
      "<your Amazon MSK Serverless subnetId-2>"
    ],
    "internal": {
      "server": "<your Amazon MSK Serverless bootstrap server>"
    },
    "external": {
      "server": "<your custom domain bootstrap server>",
      "certificate": "<your custom domain wildcard tls certificate key ARN>"
    }
  },
  "SecurePrivateAccessClient":
  {
    "vpcId": "<your remote client VPC ID>",
    "subnetIds": [
      "<your remote client subnetId-1>"
    ],
    "server": "<your custom domain bootstrap server>"
  },
  "SecurePublicAccess":
  {
    "vpcId": "<your Amazon MSK Provisioned VPC ID>",
    "subnetIds": [
      "<your Amazon MSK Provisioned subnetId-1>",
      "<your Amazon MSK Provisioned subnetId-2>"
    ],
    "internal": {
      "servers": "<your Amazon MSK Provisioned bootstrap servers>",
      "trust": "<your Amazon MSK Provisioned Certificate Authority ARN>"
    },
    "external": {
      "servers": "<your custom domain bootstrap servers>",
      "certificate": "<your custom domain wildcard tls certificate key ARN>",
      "trust": "<your custom domain Certificate Authority ARN, defaults to same as Amazon MSK>"
    }
  },
  "MskProvisionedCluster": {
    "authentication": {
      "unauthenticated": false,
      "sasl": {
        "iam": false,
        "scram": "alice"
      },
      "mtls": [ "<your Amazon MSK Provisioned Certificate Authority ARN>" ]
    }
  }
}
